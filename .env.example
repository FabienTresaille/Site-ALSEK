# ══════════════════════════════════════════════
# Alsek Website — Variables d'environnement
# Copier en .env.local pour le développement
# ══════════════════════════════════════════════

# Domaine (utilisé par Traefik)
DOMAIN=alsek.fr

# Formulaire de contact
# Option A — Resend (recommandé)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=contact@alsek.fr

# Option B — SMTP classique
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@email.fr
# SMTP_PASS=votre_mot_de_passe

# Analytics (optionnel)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=alsek.fr
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# App
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
